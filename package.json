{
  "name": "agent-reviewer",
  "displayName": "Agent Reviewer",
  "description": "GitHub PR-style line comments on diffs, staged in VS Code and delivered to your coding agent (Codex chat chip or Kimi CLI hook) with one click",
  "version": "0.5.0",
  "publisher": "NihilDigit",
  "author": "NihilDigit",
  "repository": {
    "type": "git",
    "url": "https://github.com/NihilDigit/agent-reviewer.git"
  },
  "license": "MIT",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.96.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Agent Reviewer writes a workspace mirror file and updates the repository-local Git exclude file."
    }
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentReviewer.addComment",
        "title": "Add review comment",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "agentReviewer.replyComment",
        "title": "Add note",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "agentReviewer.editComment",
        "title": "Edit note"
      },
      {
        "command": "agentReviewer.saveComment",
        "title": "Save note",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "agentReviewer.deleteComment",
        "title": "Delete note"
      },
      {
        "command": "agentReviewer.deleteThread",
        "title": "Delete thread"
      },
      {
        "command": "agentReviewer.flushReviews",
        "title": "Agent Reviewer: Flush Reviews to File",
        "icon": "$(send)"
      },
      {
        "command": "agentReviewer.addReviewComment",
        "title": "Agent Reviewer: Add Review Comment",
        "icon": "$(comment-add)"
      },
      {
        "command": "agentReviewer.clearStaged",
        "title": "Agent Reviewer: Clear Staged Reviews",
        "icon": "$(clear-all)"
      },
      {
        "command": "agentReviewer.openPendingFile",
        "title": "Agent Reviewer: Open Pending Reviews File"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "agentReviewer.addComment",
          "when": "false"
        },
        {
          "command": "agentReviewer.replyComment",
          "when": "false"
        },
        {
          "command": "agentReviewer.editComment",
          "when": "false"
        },
        {
          "command": "agentReviewer.saveComment",
          "when": "false"
        },
        {
          "command": "agentReviewer.deleteComment",
          "when": "false"
        },
        {
          "command": "agentReviewer.deleteThread",
          "when": "false"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "agentReviewer.addComment",
          "group": "inline",
          "when": "commentController == agent-review && commentThreadIsEmpty"
        },
        {
          "command": "agentReviewer.replyComment",
          "group": "inline",
          "when": "commentController == agent-review && !commentThreadIsEmpty"
        }
      ],
      "comments/comment/title": [
        {
          "command": "agentReviewer.editComment",
          "group": "inline@1",
          "when": "commentController == agent-review && comment =~ /canEdit/"
        },
        {
          "command": "agentReviewer.deleteComment",
          "group": "inline@2",
          "when": "commentController == agent-review"
        }
      ],
      "comments/comment/context": [
        {
          "command": "agentReviewer.saveComment",
          "group": "inline",
          "when": "commentController == agent-review"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "agentReviewer.flushReviews",
          "group": "inline@1",
          "when": "commentController == agent-review"
        },
        {
          "command": "agentReviewer.deleteThread",
          "group": "inline@2",
          "when": "commentController == agent-review"
        }
      ],
      "editor/title": [
        {
          "command": "agentReviewer.flushReviews",
          "group": "navigation",
          "when": "isInDiffEditor && agentReviewer.hasStaged"
        },
        {
          "command": "agentReviewer.clearStaged",
          "group": "navigation",
          "when": "agentReviewer.hasStaged"
        }
      ],
      "editor/context": [
        {
          "command": "agentReviewer.addReviewComment",
          "group": "agent-reviewer@1",
          "when": "editorTextFocus"
        }
      ]
    },
    "keybindings": [
      {
        "command": "agentReviewer.addReviewComment",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Agent Reviewer",
      "properties": {
        "agentReviewer.pendingFile": {
          "type": "string",
          "default": ".agent-reviewer/pending-reviews.md",
          "description": "Workspace-relative path of the file that mirrors the staged reviews and is handed to the agent (Codex chat chip and/or Kimi CLI hook)"
        },
        "agentReviewer.gitExclude": {
          "type": "boolean",
          "default": true,
          "description": "Automatically add the pending reviews file (and its .consumed marker) to the repository's .git/info/exclude so they never show up in git status"
        },
        "agentReviewer.targets.codex": {
          "type": "boolean",
          "default": true,
          "description": "Attach the pending reviews file to the Codex chat composer when flushing reviews"
        },
        "agentReviewer.targets.kimi": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Kimi CLI hook protocol: watch the pending reviews file and clear staged reviews when the agent consumes it"
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "package:marketplace": "cp README.md .README.md.bak; sed -i 's#https://raw.githubusercontent.com/NihilDigit/agent-reviewer/main/assets/flow.svg#assets/flow.png#' README.md; vsce package; rc=$?; mv .README.md.bak README.md; exit $rc",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.96.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.0"
  }
}
